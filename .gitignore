__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# ─── Logs ─────────────────────────────────────────────────────────────────────
logs/
*.log

# ─── OS & Editor Files ────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/

